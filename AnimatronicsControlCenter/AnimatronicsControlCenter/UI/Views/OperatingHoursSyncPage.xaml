<Page
    x:Class="AnimatronicsControlCenter.UI.Views.OperatingHoursSyncPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Command="{x:Bind ViewModel.LoadScheduleCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="Refresh from server"/>
                </StackPanel>
            </Button>
            <Button Command="{x:Bind ViewModel.SyncCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE74C;" FontSize="14"/>
                    <TextBlock Text="Send to devices"/>
                </StackPanel>
            </Button>
            <Button Command="{x:Bind ViewModel.ReadAndCompareCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8EF;" FontSize="14"/>
                    <TextBlock Text="Read and compare"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="24" RowSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Store" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.StoreNameText, Mode=OneWay}"/>
            <TextBlock Grid.Column="2" Text="Store ID" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Grid.Column="3" Text="{x:Bind ViewModel.StoreIdText, Mode=OneWay}"/>

            <TextBlock Grid.Row="1" Text="Server timezone" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.ServerTimezoneText, Mode=OneWay}"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Settings offset" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Grid.Row="1" Grid.Column="3" Text="{x:Bind ViewModel.CurrentTimezoneOffsetText, Mode=OneWay}"/>

            <TextBlock Grid.Row="2" Text="Modified" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.ModifiedAtText, Mode=OneWay}"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="Status" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Grid.Row="2" Grid.Column="3" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="Wrap"/>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Start device ID" VerticalAlignment="Center"/>
            <NumberBox Grid.Column="1" Value="{x:Bind ViewModel.StartDeviceId, Mode=TwoWay}"/>
            <TextBlock Grid.Column="2" Text="End device ID" VerticalAlignment="Center"/>
            <NumberBox Grid.Column="3" Value="{x:Bind ViewModel.EndDeviceId, Mode=TwoWay}"/>
            <TextBlock Grid.Column="4"
                       Text="{x:Bind ViewModel.TimezoneWarningText, Mode=OneWay}"
                       Foreground="{ThemeResource SystemFillColorCautionBrush}"
                       TextWrapping="Wrap"/>
        </Grid>

        <ListView Grid.Row="3" ItemsSource="{x:Bind ViewModel.DeviceResults, Mode=OneWay}">
            <ListView.Header>
                <Grid ColumnSpacing="12" Padding="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Device" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Grid.Column="1" Text="Write" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Grid.Column="2" Text="Read" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Grid.Column="3" Text="Checksum" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Grid.Column="4" Text="Message" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:OperatingHoursDeviceResultViewModel"
                              xmlns:viewModels="using:AnimatronicsControlCenter.UI.ViewModels">
                    <Grid ColumnSpacing="12" Padding="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind DeviceId}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind WriteStatus}"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind ReadStatus}"/>
                        <TextBlock Grid.Column="3" Text="{x:Bind DeviceChecksum}"/>
                        <TextBlock Grid.Column="4" Text="{x:Bind Message}" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
