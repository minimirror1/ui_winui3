<Page
    x:Class="AnimatronicsControlCenter.UI.Views.OperatingHoursSyncPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:AnimatronicsControlCenter.UI.ViewModels"
    xmlns:cv="using:AnimatronicsControlCenter.UI.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="OpsServerAccentBrush"  Color="#22c55e"/>
                    <SolidColorBrush x:Key="OpsDeviceAccentBrush"  Color="#60a5fa"/>
                    <SolidColorBrush x:Key="OpsAutoSyncBadgeBrush" Color="#1d4ed8"/>
                    <SolidColorBrush x:Key="OpsPaneBgBrush"        Color="#ffffff"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="OpsServerAccentBrush"  Color="#4ade80"/>
                    <SolidColorBrush x:Key="OpsDeviceAccentBrush"  Color="#60a5fa"/>
                    <SolidColorBrush x:Key="OpsAutoSyncBadgeBrush" Color="#3b82f6"/>
                    <SolidColorBrush x:Key="OpsPaneBgBrush"        Color="#1e1e1e"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <cv:BoolToVisibilityConverter         x:Key="BoolToVisibility"/>
            <cv:InverseBoolToVisibilityConverter   x:Key="InverseBoolToVisibility"/>
            <cv:OpsDiffHighlightConverter          x:Key="DiffHighlight"/>
            <cv:OpsDeviceStatusBadgeToBrushConverter x:Key="StatusBadgeToBrush"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Page header ──────────────────────────────────────────────────── -->
        <Border Padding="24,18,24,14"
                BorderThickness="0,0,0,1"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid>
                <StackPanel Spacing="2">
                    <TextBlock Text="운영 시간 동기화"
                               Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock Text="{x:Bind ViewModel.StoreId, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="{ThemeResource OpsAutoSyncBadgeBrush}"
                        CornerRadius="999" Padding="12,5"
                        Visibility="{x:Bind ViewModel.ShowAutoSyncBadge, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{x:Bind ViewModel.AutoSyncBadgeText, Mode=OneWay}"
                               Foreground="White" FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <!-- ── Two-pane content ─────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Padding="24,16,24,24" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ════════════════════════════════════════════════════════════
                     SERVER PANE
                ════════════════════════════════════════════════════════════ -->
                <Border CornerRadius="12"
                        Background="{ThemeResource OpsPaneBgBrush}"
                        BorderThickness="0,3,0,0"
                        BorderBrush="{ThemeResource OpsServerAccentBrush}">
                    <StackPanel Padding="16,14,16,16" Spacing="14">

                        <!-- Head: title + action buttons -->
                        <Grid>
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="서버 스케쥴"
                                           FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind ViewModel.StoreInfoText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{x:Bind ViewModel.IsServerScheduleLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Content="서버에서 불러오기"
                                        Command="{x:Bind ViewModel.LoadFromServerCommand}"
                                        Style="{StaticResource AccentButtonStyle}"/>
                                <Button Content="서버로 전송"
                                        Command="{x:Bind ViewModel.PushToServerCommand}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Schedule column headers -->
                        <Grid ColumnSpacing="6" Padding="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="요일"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="오픈"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="마감"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="휴무"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>

                        <!-- Editable schedule rows -->
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.ServerDays, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:OpsHoursDayEditVm">
                                    <Grid ColumnSpacing="6" MinHeight="48" Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{x:Bind DayLabel}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>

                                        <!-- Open time picker (visible when not closed) -->
                                        <TimePicker Grid.Column="1"
                                                    Time="{x:Bind OpenTime, Mode=TwoWay}"
                                                    ClockIdentifier="24HourClock"
                                                    Visibility="{x:Bind IsNotClosed, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                                    MinWidth="0"/>

                                        <!-- 휴무일 pill (spans open+close columns when closed) -->
                                        <Border Grid.Column="1" Grid.ColumnSpan="2"
                                                Visibility="{x:Bind IsClosed, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                                Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                                CornerRadius="999" Padding="12,5">
                                            <TextBlock Text="휴무일" FontSize="12"/>
                                        </Border>

                                        <!-- Close time picker (visible when not closed) -->
                                        <TimePicker Grid.Column="2"
                                                    Time="{x:Bind CloseTime, Mode=TwoWay}"
                                                    ClockIdentifier="24HourClock"
                                                    Visibility="{x:Bind IsNotClosed, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                                    MinWidth="0"/>

                                        <!-- Closed toggle -->
                                        <CheckBox Grid.Column="3"
                                                  IsChecked="{x:Bind IsClosed, Mode=TwoWay}"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- Status message -->
                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{x:Bind ViewModel.IsServerScheduleLoaded, Mode=OneWay, Converter={StaticResource InverseBoolToVisibility}}"/>
                    </StackPanel>
                </Border>

                <!-- ════════════════════════════════════════════════════════════
                     DEVICE PANE
                ════════════════════════════════════════════════════════════ -->
                <Border Grid.Column="1" CornerRadius="12"
                        Background="{ThemeResource OpsPaneBgBrush}"
                        BorderThickness="0,3,0,0"
                        BorderBrush="{ThemeResource OpsDeviceAccentBrush}">
                    <StackPanel Padding="16,14,16,16" Spacing="12">

                        <!-- Head: title + range inputs -->
                        <Grid>
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="장치 스케쥴"
                                           FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind ViewModel.DeviceCountText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" Spacing="6">
                                <NumberBox Value="{x:Bind ViewModel.DeviceRangeFrom, Mode=TwoWay}"
                                           Minimum="1" Maximum="254" Width="72"
                                           SpinButtonPlacementMode="Compact"/>
                                <TextBlock Text="~" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <NumberBox Value="{x:Bind ViewModel.DeviceRangeTo, Mode=TwoWay}"
                                           Minimum="1" Maximum="254" Width="72"
                                           SpinButtonPlacementMode="Compact"/>
                            </StackPanel>
                        </Grid>

                        <!-- Navigation row: ‹ #003 [status badge] › -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="‹" Command="{x:Bind ViewModel.NavigatePrevCommand}"
                                    Width="36" Padding="0" VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.DeviceNavText, Mode=OneWay}"
                                       FontFamily="Consolas" FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="4,0"/>

                            <Border Grid.Column="2"
                                    Background="{x:Bind ViewModel.DeviceStatusBadge, Mode=OneWay, Converter={StaticResource StatusBadgeToBrush}}"
                                    CornerRadius="999" Padding="10,4"
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.DeviceStatusText, Mode=OneWay}"
                                           Foreground="White" FontSize="11"/>
                            </Border>

                            <Button Grid.Column="3" Content="›"
                                    Command="{x:Bind ViewModel.NavigateNextCommand}"
                                    Width="36" Padding="0" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Batch progress bar (visible during batch operations) -->
                        <StackPanel Spacing="5"
                                    Visibility="{x:Bind ViewModel.IsBatchInProgress, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <Grid>
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                                    <Run Text="{x:Bind ViewModel.BatchLabel, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{x:Bind ViewModel.BatchDone, Mode=OneWay}"/>
                                    <Run Text="/"/>
                                    <Run Text="{x:Bind ViewModel.BatchTotal, Mode=OneWay}"/>
                                </TextBlock>
                            </Grid>
                            <ProgressBar Value="{x:Bind ViewModel.BatchProgressValue, Mode=OneWay}"
                                         Maximum="100" Height="4"/>
                        </StackPanel>

                        <!-- Device schedule column headers -->
                        <Grid ColumnSpacing="6" Padding="4,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="요일"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="오픈"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="마감"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>

                        <!-- Read-only device schedule rows (amber highlight on diff) -->
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.DeviceDays, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:OpsHoursDayDisplayVm">
                                    <Border Margin="0,2" CornerRadius="6"
                                            Background="{x:Bind IsDiff, Mode=OneWay, Converter={StaticResource DiffHighlight}}">
                                        <Grid ColumnSpacing="6" Padding="4,8" MinHeight="40">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{x:Bind DayLabel}"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>

                                            <!-- Open text: "휴무" or HH:MM -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind OpenText, Mode=OneWay}"
                                                       FontFamily="Consolas"
                                                       VerticalAlignment="Center"/>

                                            <!-- Close text -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind CloseText, Mode=OneWay}"
                                                       FontFamily="Consolas"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- Footer: 4 action buttons -->
                        <Grid ColumnSpacing="6" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="현재 비교"
                                    Command="{x:Bind ViewModel.CompareCurrentDeviceCommand}"
                                    HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="1" Content="현재 전송"
                                    Command="{x:Bind ViewModel.SendToCurrentDeviceCommand}"
                                    HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="2" Content="일괄 비교"
                                    Command="{x:Bind ViewModel.CompareAllDevicesCommand}"
                                    HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="3" Content="일괄 전송"
                                    Command="{x:Bind ViewModel.SendToAllDevicesCommand}"
                                    HorizontalAlignment="Stretch"/>
                        </Grid>

                        <!-- Status message (bottom of device pane) -->
                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{x:Bind ViewModel.IsServerScheduleLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
