<Page
    x:Class="AnimatronicsControlCenter.UI.Views.OperatingHoursSyncPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:AnimatronicsControlCenter.UI.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="ScheduleAccentBrush" Color="#0078D4"/>
                    <SolidColorBrush x:Key="ScheduleOpenBrush" Color="#047857"/>
                    <SolidColorBrush x:Key="ScheduleClosedBrush" Color="#991B1B"/>
                    <SolidColorBrush x:Key="ScheduleChipBackgroundBrush" Color="#ECFDF5"/>
                    <SolidColorBrush x:Key="ScheduleMutedChipBackgroundBrush" Color="#FEE2E2"/>
                    <SolidColorBrush x:Key="ScheduleDevicePanelBrush" Color="#F8FAFC"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="ScheduleAccentBrush" Color="#5BCEFF"/>
                    <SolidColorBrush x:Key="ScheduleOpenBrush" Color="#86EFAC"/>
                    <SolidColorBrush x:Key="ScheduleClosedBrush" Color="#FFB4AB"/>
                    <SolidColorBrush x:Key="ScheduleChipBackgroundBrush" Color="#173524"/>
                    <SolidColorBrush x:Key="ScheduleMutedChipBackgroundBrush" Color="#3A1F24"/>
                    <SolidColorBrush x:Key="ScheduleDevicePanelBrush" Color="#242424"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <CommandBar DefaultLabelPosition="Right" Background="Transparent" IsOpen="False">
            <AppBarButton Icon="Refresh" Label="Refresh from server" Command="{x:Bind ViewModel.LoadScheduleCommand}"/>
            <AppBarButton Icon="Upload" Label="Send to devices" Command="{x:Bind ViewModel.SyncCommand}"/>
            <AppBarButton Icon="Calculator" Label="Read and compare" Command="{x:Bind ViewModel.ReadAndCompareCommand}"/>
            <CommandBar.Content>
                <StackPanel Margin="12,10,0,0" Spacing="2">
                    <TextBlock Text="Operating hours sync" Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
            </CommandBar.Content>
        </CommandBar>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Padding="24,12,24,24" RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="0.8*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="18"
                          RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.RowSpan="2"
                                Width="5"
                                HorizontalAlignment="Left"
                                Margin="-18"
                                CornerRadius="8,0,0,8"
                                Background="{ThemeResource ScheduleAccentBrush}"/>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.StoreNameText, Mode=OneWay}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind ViewModel.StoreIdText, Mode=OneWay}"
                                           FontFamily="Consolas"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                    CornerRadius="999"
                                    Padding="10,5"
                                    VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE823;" FontFamily="Segoe Fluent Icons" FontSize="12"/>
                                    <TextBlock Text="{x:Bind ViewModel.ServerTimezoneText, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Modified"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.ModifiedAtText, Mode=OneWay}"
                                           FontFamily="Consolas"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Settings offset"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.CurrentTimezoneOffsetText, Mode=OneWay}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Checksum"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.Schedule.Checksum, Mode=OneWay, FallbackValue='-'}"
                                           FontFamily="Consolas"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Grid Grid.Column="1"
                          Background="{ThemeResource ScheduleDevicePanelBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="18"
                          RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE950;" FontFamily="Segoe Fluent Icons" FontSize="16"/>
                            <TextBlock Text="Device range" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        </StackPanel>
                        <Grid Grid.Row="1" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="5">
                                <TextBlock Text="Start ID"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <NumberBox Value="{x:Bind ViewModel.StartDeviceId, Mode=TwoWay}"
                                           Minimum="1"
                                           Maximum="254"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="5">
                                <TextBlock Text="End ID"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <NumberBox Value="{x:Bind ViewModel.EndDeviceId, Mode=TwoWay}"
                                           Minimum="1"
                                           Maximum="254"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Grid.Row="2"
                                   Text="{x:Bind ViewModel.TimezoneWarningText, Mode=OneWay}"
                                   Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                    </Grid>
                </Grid>

                <Grid Grid.Row="1" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE121;" FontFamily="Segoe Fluent Icons" FontSize="16"/>
                            <TextBlock Text="Weekly schedule" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        </StackPanel>
                        <TextBlock Text="Server order is normalized to Monday through Sunday"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    </Grid>

                    <Grid Grid.Row="1"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="16"
                          RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="14" Padding="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Day" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Grid.Column="1" Text="Status" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Grid.Column="2" Text="Open" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Grid.Column="3" Text="Close" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Grid.Column="4" Text="Range" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </Grid>

                        <ListView Grid.Row="1"
                                  ItemsSource="{x:Bind ViewModel.ScheduleDays, Mode=OneWay}"
                                  SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="MinHeight" Value="44"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:OperatingHoursDayViewModel">
                                    <Grid ColumnSpacing="14" Padding="0,7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind DayOfWeek}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="1"
                                                Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                                CornerRadius="999"
                                                Padding="8,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="{x:Bind StatusGlyph}"
                                                          FontFamily="Segoe Fluent Icons"
                                                          FontSize="11"
                                                          VerticalAlignment="Center"/>
                                                <TextBlock Text="{x:Bind StatusText}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind OpenText}"
                                                   FontFamily="Consolas"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{x:Bind CloseText}"
                                                   FontFamily="Consolas"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="{x:Bind TimeRangeText}"
                                                   FontFamily="Consolas"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>

                <Grid Grid.Row="2"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="16"
                      RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8EF;" FontFamily="Segoe Fluent Icons" FontSize="16"/>
                            <TextBlock Text="Device sync results" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        </StackPanel>
                    </Grid>

                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.DeviceResults, Mode=OneWay}">
                        <ListView.Header>
                            <Grid ColumnSpacing="12" Padding="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Device" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Grid.Column="1" Text="Write" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Grid.Column="2" Text="Read" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Grid.Column="3" Text="Checksum" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Grid.Column="4" Text="Message" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:OperatingHoursDeviceResultViewModel">
                                <Grid ColumnSpacing="12" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind DeviceId}"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind WriteStatus}"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind ReadStatus}"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind DeviceChecksum}"/>
                                    <TextBlock Grid.Column="4" Text="{x:Bind Message}" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
