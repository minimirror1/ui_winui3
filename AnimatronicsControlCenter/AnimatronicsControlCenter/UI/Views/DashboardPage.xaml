<Page
    x:Class="AnimatronicsControlCenter.UI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AnimatronicsControlCenter.Core.Models"
    xmlns:cv="using:AnimatronicsControlCenter.UI.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <cv:BoolToColorBrushConverter x:Key="ConnectionColorConverter"/>
        <cv:DeviceCardStatusToBrushConverter x:Key="CardStatusToBrush"/>
        <cv:DeviceCardStatusToLabelConverter x:Key="CardStatusToLabel"/>
        <cv:MotionStateToBrushConverter x:Key="MotionStateToBrush"/>
        <cv:PowerStatusToBrushConverter x:Key="PowerStatusToBrush"/>
        <cv:MotionStateToButtonLabelConverter x:Key="MotionStateToButtonLabel"/>
        <cv:MotionStateToButtonIconConverter x:Key="MotionStateToButtonIcon"/>
        <cv:TimeSpanToShortStringConverter x:Key="TimeSpanToShortString"/>
        <cv:IntToPaddedIdConverter x:Key="IntToPaddedId"/>
        <SolidColorBrush x:Key="DashboardDeviceCardBackgroundBrush" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="DashboardDeviceCardHoverBackgroundBrush" Color="#303030"/>
        <SolidColorBrush x:Key="DashboardPlayButtonBackgroundBrush" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="DashboardPlayButtonBorderBrush" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="DashboardPlayButtonForegroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="DashboardPlayButtonHoverBackgroundBrush" Color="#5BCEFF"/>
        <SolidColorBrush x:Key="DashboardPlayButtonHoverForegroundBrush" Color="#111111"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <CommandBar DefaultLabelPosition="Right" Background="Transparent" IsOpen="False">
            <AppBarButton x:Uid="Dashboard_Scan" Icon="Refresh" Command="{x:Bind ViewModel.ScanCommand}"/>
            <CommandBar.Content>
                <TextBlock x:Uid="Dashboard_Devices" Style="{StaticResource TitleTextBlockStyle}" Margin="12,14,0,0"/>
            </CommandBar.Content>
        </CommandBar>

        <GridView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Devices}" Padding="12"
                  SelectionMode="None">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Device">
                    <!-- Card root: 320x216, tapped for navigation -->
                    <Grid Width="320" Height="216"
                          Background="{StaticResource DashboardDeviceCardBackgroundBrush}"
                          CornerRadius="8" Padding="14"
                          BorderThickness="1"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          Tag="{x:Bind}"
                          PointerEntered="Card_PointerEntered"
                          PointerExited="Card_PointerExited"
                          Tapped="Card_Tapped">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.RowSpan="4"
                                Width="5"
                                HorizontalAlignment="Left"
                                Margin="-14"
                                CornerRadius="8,0,0,8"
                                Background="{x:Bind CardStatus, Mode=OneWay, Converter={StaticResource CardStatusToBrush}}"/>

                        <!-- Header -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="96"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: ID badge + name + status -->
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <!-- ID badge -->
                                    <TextBlock Text="{x:Bind Id, Mode=OneWay, Converter={StaticResource IntToPaddedId}}"
                                               FontFamily="Segoe UI Light"
                                               FontSize="54"
                                               FontWeight="Light"
                                               LineHeight="58"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <!-- Device name -->
                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                               FontSize="15.5"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                </StackPanel>
                                <!-- Status label + dot -->
                                <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,2,0,0">
                                    <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                             Fill="{x:Bind CardStatus, Mode=OneWay, Converter={StaticResource CardStatusToBrush}}"/>
                                    <TextBlock Text="{x:Bind CardStatus, Mode=OneWay, Converter={StaticResource CardStatusToLabel}}"
                                               FontSize="11"
                                               Foreground="{x:Bind CardStatus, Mode=OneWay, Converter={StaticResource CardStatusToBrush}}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Right: indicator rows -->
                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                <!-- Com row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Com" FontSize="10"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <Ellipse Grid.Column="1" Width="7" Height="7"
                                             Fill="{x:Bind IsConnected, Mode=OneWay, Converter={StaticResource ConnectionColorConverter}}"/>
                                </Grid>
                                <!-- Relay row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Relay" FontSize="10"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <Ellipse Grid.Column="1" Width="7" Height="7"
                                             Fill="{x:Bind PowerStatus, Mode=OneWay, Converter={StaticResource PowerStatusToBrush}}"/>
                                </Grid>
                                <!-- Play row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Play" FontSize="10"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <Ellipse Grid.Column="1" Width="7" Height="7"
                                             Fill="{x:Bind MotionState, Mode=OneWay, Converter={StaticResource MotionStateToBrush}}"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Spacer -->
                        <Grid Grid.Row="1"/>

                        <!-- Timeline row -->
                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="3"/>
                            </Grid.RowDefinitions>
                            <!-- Time labels -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind MotionCurrentTime, Mode=OneWay, Converter={StaticResource TimeSpanToShortString}}"
                                           FontFamily="Consolas" FontSize="10"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Grid.Column="1"
                                           FontFamily="Consolas" FontSize="10"
                                           HorizontalAlignment="Center"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}">
                                    <Run Text="{x:Bind Motors.Count, Mode=OneWay}"/>
                                    <Run Text=" MOTORS"/>
                                </TextBlock>
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind MotionTotalTime, Mode=OneWay, Converter={StaticResource TimeSpanToShortString}}"
                                           FontFamily="Consolas" FontSize="10"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            </Grid>
                            <!-- Progress bar -->
                            <ProgressBar Grid.Row="1" Height="3"
                                         Minimum="0" Maximum="1"
                                         Value="{x:Bind MotionProgress, Mode=OneWay}"
                                         Foreground="{x:Bind CardStatus, Mode=OneWay, Converter={StaticResource CardStatusToBrush}}"
                                         Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"/>
                        </Grid>

                        <!-- Footer -->
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Play/Stop button (visual only) -->
                            <Button x:Name="PlayStopButton"
                                    Click="PlayStopButton_Click"
                                    Tag="{x:Bind}"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource DashboardPlayButtonBackgroundBrush}"
                                    BorderBrush="{StaticResource DashboardPlayButtonBorderBrush}"
                                    Foreground="{StaticResource DashboardPlayButtonForegroundBrush}"
                                    Padding="12,6">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5BCEFF"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#5BCEFF"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#111111"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#47BCEB"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#47BCEB"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#111111"/>
                                </Button.Resources>
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="{x:Bind MotionState, Mode=OneWay, Converter={StaticResource MotionStateToButtonIcon}}"
                                                  FontFamily="Segoe Fluent Icons"
                                                  FontSize="12"
                                                  Foreground="{StaticResource DashboardPlayButtonForegroundBrush}"/>
                                        <TextBlock Text="{x:Bind MotionState, Mode=OneWay, Converter={StaticResource MotionStateToButtonLabel}}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource DashboardPlayButtonForegroundBrush}"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <!-- Details button -->
                            <Button Grid.Column="1" Content="Details"
                                    Click="DetailsButton_Click"
                                    Tag="{x:Bind}"
                                    HorizontalAlignment="Right"
                                    Padding="14,5"/>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <ProgressBar Grid.Row="1" IsIndeterminate="True" Visibility="{x:Bind BoolToVisibility(ViewModel.IsScanning), Mode=OneWay}" VerticalAlignment="Top"/>
    </Grid>
</Page>
