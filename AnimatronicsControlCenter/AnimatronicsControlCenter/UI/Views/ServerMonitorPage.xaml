<Page
    x:Class="AnimatronicsControlCenter.UI.Views.ServerMonitorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="24" RowSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Server URL" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.ServerUrl, Mode=OneWay}"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Connection" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.ConnectionStatus, Mode=OneWay}"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Last success" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.LastSuccess, Mode=OneWay}"/>
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Last failure" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.LastFailure, Mode=OneWay}"/>
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Latest error" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.LatestError, Mode=OneWay}" TextWrapping="Wrap"/>
        </Grid>

        <Grid Grid.Row="1" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Recent backend traffic" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <ListView x:Name="TrafficList"
                      Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.TrafficEntries, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:ServerTrafficEntryViewModel"
                                  xmlns:viewModels="using:AnimatronicsControlCenter.UI.ViewModels">
                        <Grid ColumnSpacing="12" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92"/>
                                <ColumnDefinition Width="76"/>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Time}"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind Phase}"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind Method}"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind Path}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="4" Text="{x:Bind StatusCode}"/>
                            <TextBlock Grid.Column="5" Text="{x:Bind Duration}"/>
                            <TextBlock Grid.Column="6" Text="{x:Bind Message}" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
