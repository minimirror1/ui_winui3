<Page
    x:Class="AnimatronicsControlCenter.UI.Views.BackendSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:backend="using:AnimatronicsControlCenter.Core.Backend">

    <Grid Padding="24" ColumnSpacing="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel x:Name="ServerValuesPanel" Spacing="12">
            <TextBlock Text="Server Values" Style="{StaticResource SubtitleTextBlockStyle}" />
            <Button Content="서버 데이터(Store/PC/Object) 등록/수정"
                    Click="OnOpenRegistrationDialogClicked"
                    IsEnabled="{x:Bind ViewModel.IsRegistrationAvailable, Mode=OneWay}"
                    HorizontalAlignment="Stretch" />
            <TextBlock Text="Country Code를 먼저 선택하면 데이터 관리가 활성화됩니다."
                       Visibility="{x:Bind BoolToVisibility(ViewModel.ShouldShowRegistrationCountryCodeHint), Mode=OneWay}"
                       TextWrapping="Wrap" />
            <Button Content="{x:Bind ViewModel.ServerConnectionEditButtonText, Mode=OneWay}"
                    Command="{x:Bind ViewModel.ToggleServerConnectionEditingCommand}"
                    HorizontalAlignment="Stretch" />
            <TextBlock Text="서버 접속 정보는 잠겨 있습니다."
                       Visibility="{x:Bind BoolToVisibility(ViewModel.ShouldShowServerConnectionLockedMessage), Mode=OneWay}"
                       TextWrapping="Wrap" />
            <TextBox Header="Base URL"
                     Text="{x:Bind ViewModel.BackendBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{x:Bind BoolToVisibility(ViewModel.IsServerConnectionEditing), Mode=OneWay}" />
            <PasswordBox Header="Bearer Token"
                         Password="{x:Bind ViewModel.BackendBearerToken, Mode=TwoWay}"
                         Visibility="{x:Bind BoolToVisibility(ViewModel.IsServerConnectionEditing), Mode=OneWay}" />
            <ComboBox Header="Country Code"
                      ItemsSource="{x:Bind ViewModel.AvailableCountryCodes}"
                      SelectedItem="{x:Bind ViewModel.SelectedCountryCode, Mode=TwoWay}"
                      HorizontalAlignment="Stretch" />
            <ComboBox Header="Store"
                      ItemsSource="{x:Bind ViewModel.ServerStoreList, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedServerStore, Mode=TwoWay}"
                      DisplayMemberPath="StoreName"
                      HorizontalAlignment="Stretch" />
            <ComboBox Header="PC"
                      ItemsSource="{x:Bind ViewModel.ServerPcList, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedServerPc, Mode=TwoWay}"
                      DisplayMemberPath="PcName"
                      HorizontalAlignment="Stretch" />
            <TextBlock Text="{x:Bind ViewModel.ServerStatusMessage, Mode=OneWay}" TextWrapping="Wrap" />
            <TextBlock Text="서버 오브제" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <Grid x:Name="ServerObjectListHeader" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="오브제 이름" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Grid.Column="1" Text="서버 오브제 ID" Style="{StaticResource BodyStrongTextBlockStyle}" />
            </Grid>
            <ListView ItemsSource="{x:Bind ViewModel.ServerObjects, Mode=OneWay}"
                      MaxHeight="220">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="backend:BackendServerObjectSnapshot">
                        <Grid ColumnSpacing="12" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind ObjectName}" TextWrapping="Wrap" />
                            <TextBlock Grid.Column="1" Text="{x:Bind ObjectId}" TextWrapping="Wrap" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <Button Grid.Column="1"
                Content="서버 값 적용"
                Command="{x:Bind ViewModel.ApplyServerValuesCommand}"
                VerticalAlignment="Center" />

        <ScrollViewer Grid.Column="2">
            <StackPanel x:Name="LocalSettingsPanel" Spacing="12" Padding="0,0,16,0">
                <TextBlock Text="Local Settings" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Button x:Name="OpenLocalSettingsFileButton"
                        Content="로컬 설정 파일 열기"
                        Click="OnOpenLocalSettingsFileClicked"
                        HorizontalAlignment="Stretch" />
                <ToggleSwitch Header="Sync Enabled" IsOn="{x:Bind ViewModel.IsBackendSyncEnabled, Mode=TwoWay}" />
                <NumberBox Header="Sync Interval Seconds" Value="{x:Bind ViewModel.BackendSyncIntervalSeconds, Mode=TwoWay}" Minimum="1" />
                <TextBox Header="Store ID" Text="{x:Bind ViewModel.BackendStoreId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Store Name" Text="{x:Bind ViewModel.BackendStoreName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Store Country Code" Text="{x:Bind ViewModel.BackendStoreCountryCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="{x:Bind ViewModel.StoreCountryCodeComparisonMessage, Mode=OneWay}" Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}" TextWrapping="Wrap" />
                <TextBox Header="PC ID" Text="{x:Bind ViewModel.BackendPcId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="{x:Bind ViewModel.PcIdComparisonMessage, Mode=OneWay}" Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}" TextWrapping="Wrap" />
                <TextBox Header="PC Name" Text="{x:Bind ViewModel.BackendPcName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Software Version" Text="{x:Bind ViewModel.BackendSoftwareVersion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="{x:Bind ViewModel.SwVersionComparisonMessage, Mode=OneWay}" Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}" TextWrapping="Wrap" />
                <TextBlock Text="Object Mappings" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="오브제 이름" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Grid.Column="1" Text="서버 오브제 ID" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Grid.Column="2" Text="WinUI 로컬 ID" Style="{StaticResource BodyStrongTextBlockStyle}" />
                </Grid>
                <ListView ItemsSource="{x:Bind ViewModel.MappedServerObjects, Mode=OneWay}"
                          MaxHeight="220">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="backend:BackendObjectMappingDisplay">
                            <Grid ColumnSpacing="12" Padding="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind ObjectName}" TextWrapping="Wrap" />
                                <TextBlock Grid.Column="1" Text="{x:Bind ObjectId}" TextWrapping="Wrap" />
                                <TextBlock Grid.Column="2" Text="{x:Bind LocalObjectIdText}" TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button x:Name="EditObjectMappingsButton"
                        Content="오브제 매핑 수정"
                        Click="OnEditObjectMappingsClicked"
                        HorizontalAlignment="Stretch" />
                <TextBox Header="Device/Object Mapping JSON"
                         Text="{x:Bind ViewModel.BackendDeviceObjectMappingsText, Mode=OneWay}"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         MinHeight="120" />
                <TextBlock Text="{x:Bind ViewModel.BackendDeviceObjectMappingsMessage, Mode=OneWay}" Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}" TextWrapping="Wrap" />
                <TextBlock Text="{x:Bind ViewModel.DeviceObjectMappingsComparisonMessage, Mode=OneWay}" Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="서버 값 비교" Command="{x:Bind ViewModel.CompareWithServerCommand}" />
                    <Button Content="저장" Command="{x:Bind ViewModel.SaveCommand}" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
                <TextBlock Text="{x:Bind ViewModel.LocalStatusMessage, Mode=OneWay}" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
