<ContentDialog
    x:Class="AnimatronicsControlCenter.UI.Views.BackendApiKeyPromptDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="서버 API 키 설정"
    PrimaryButtonText="저장"
    CloseButtonText="나중에"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}"
    Loaded="OnLoaded"
    MinWidth="440">

    <StackPanel Spacing="14" Padding="0,4,0,4">
        <InfoBar Title="서버 인증이 필요합니다"
                 Message="서버 기능을 사용하려면 X-API-Key를 입력하세요. 키는 Windows PasswordVault에만 저장됩니다."
                 Severity="Informational"
                 IsClosable="False"
                 IsOpen="True" />

        <PasswordBox x:Name="ApiKeyPasswordBox"
                     Header="X-API-Key"
                     PlaceholderText="서버 API 키를 입력하세요"
                     PasswordRevealMode="Peek"
                     Password="{x:Bind ViewModel.ApiKey, Mode=TwoWay}" />

        <StackPanel Orientation="Horizontal" Spacing="8">
            <FontIcon Glyph="&#xE72E;"
                      FontSize="13"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="나중에를 선택하면 로컬 기능은 계속 사용할 수 있으며, 다음 실행 때 다시 안내합니다."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="380" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
