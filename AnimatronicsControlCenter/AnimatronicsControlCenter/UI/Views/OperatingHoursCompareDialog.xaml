<ContentDialog
    x:Class="AnimatronicsControlCenter.UI.Views.OperatingHoursCompareDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:AnimatronicsControlCenter.UI.ViewModels"
    xmlns:cv="using:AnimatronicsControlCenter.UI.Converters"
    mc:Ignorable="d"
    CloseButtonText="닫기">

    <ContentDialog.Resources>
        <cv:BoolToVisibilityConverter          x:Key="BoolToVisibility"/>
        <cv:InverseBoolToVisibilityConverter    x:Key="InverseBoolToVisibility"/>
        <cv:OpsCompareStatusToBrushConverter   x:Key="StatusToBrush"/>
        <cv:OpsDiffDayTextBrushConverter       x:Key="DiffTextBrush"/>
        <cv:OpsDiffHighlightConverter          x:Key="DiffHighlight"/>
    </ContentDialog.Resources>

    <ContentDialog.Title>
        <TextBlock Text="{x:Bind Vm.CompareTitle, Mode=OneWay}"
                   FontSize="16" FontWeight="SemiBold"/>
    </ContentDialog.Title>

    <ScrollViewer MaxHeight="560" MinWidth="680" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="0,4">

            <!-- ── Summary stats grid ─────────────────────────────────────────── -->
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 검사 장치 -->
                <Border CornerRadius="8" Padding="14,10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="검사 장치"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind Vm.CompareResults.Count, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- 일치 -->
                <Border Grid.Column="1" CornerRadius="8" Padding="14,10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="일치"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind Vm.CompareMatchCount, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#4ade80"/>
                    </StackPanel>
                </Border>

                <!-- 불일치 -->
                <Border Grid.Column="2" CornerRadius="8" Padding="14,10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="불일치"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind Vm.CompareDiffCount, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#fbbf24"/>
                    </StackPanel>
                </Border>

                <!-- 응답 없음 -->
                <Border Grid.Column="3" CornerRadius="8" Padding="14,10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="응답 없음"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind Vm.CompareErrCount, Mode=OneWay}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#ef4444"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Device result list ─────────────────────────────────────────── -->
            <ItemsRepeater ItemsSource="{x:Bind Vm.CompareResults, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:OpsCompareDeviceResultVm">
                        <Border Margin="0,4" CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <!-- Row header (tap to expand) -->
                                <Button HorizontalAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="14,10"
                                        Command="{x:Bind ToggleExpandedCommand}">
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Device ID -->
                                        <TextBlock Text="{x:Bind DeviceIdText}"
                                                   FontFamily="Consolas" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>

                                        <!-- Status tag -->
                                        <Border Grid.Column="1"
                                                Background="{x:Bind Status, Converter={StaticResource StatusToBrush}}"
                                                CornerRadius="999" Padding="8,3"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind StatusTag}"
                                                       Foreground="White" FontSize="11"/>
                                        </Border>

                                        <!-- Summary text -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind SummaryText}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   FontSize="12" Margin="10,0,0,0"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Expand chevron (only for diff) -->
                                        <FontIcon Grid.Column="3"
                                                  Glyph="{x:Bind ChevronGlyph, Mode=OneWay}"
                                                  FontFamily="Segoe Fluent Icons" FontSize="12"
                                                  VerticalAlignment="Center"
                                                  Visibility="{x:Bind HasDiffs, Converter={StaticResource BoolToVisibility}}"/>
                                    </Grid>
                                </Button>

                                <!-- Expanded detail: day-by-day diff table -->
                                <StackPanel Padding="14,0,14,12"
                                            Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">

                                    <!-- Table header -->
                                    <Grid ColumnSpacing="8" Padding="0,0,0,6"
                                          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                          BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="요일"   Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="서버 (UI)" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="3" Text="장치"      Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="4" Text="차이 항목" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Grid>

                                    <!-- Day diff rows -->
                                    <ItemsRepeater ItemsSource="{x:Bind AllDays}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="viewModels:OpsCompareDayDiff">
                                                <Border Background="{x:Bind IsDiff, Converter={StaticResource DiffHighlight}}"
                                                        CornerRadius="4" Margin="0,1">
                                                    <Grid ColumnSpacing="8" Padding="0,7">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="36"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="20"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="110"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Text="{x:Bind DayLabel}"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"/>

                                                        <TextBlock Grid.Column="1"
                                                                   Text="{x:Bind ServerValue}"
                                                                   FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{x:Bind IsDiff, Converter={StaticResource DiffTextBrush}}"
                                                                   VerticalAlignment="Center"/>

                                                        <TextBlock Grid.Column="2" Text="→"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>

                                                        <TextBlock Grid.Column="3"
                                                                   Text="{x:Bind DeviceValue}"
                                                                   FontFamily="Consolas" FontSize="12"
                                                                   Foreground="{x:Bind IsDiff, Converter={StaticResource DiffTextBrush}}"
                                                                   VerticalAlignment="Center"/>

                                                        <TextBlock Grid.Column="4"
                                                                   Text="{x:Bind DiffFields}"
                                                                   FontSize="11"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ── Footer summary text ───────────────────────────────────────── -->
            <TextBlock Text="{x:Bind Vm.CompareFooterText, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
