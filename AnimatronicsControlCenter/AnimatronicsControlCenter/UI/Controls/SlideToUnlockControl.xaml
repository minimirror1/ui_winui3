<UserControl
    x:Class="AnimatronicsControlCenter.UI.Controls.SlideToUnlockControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="320" d:DesignHeight="56">

    <Grid x:Name="RootGrid" Height="56" SizeChanged="RootGrid_SizeChanged">

        <!-- Track background -->
        <Border x:Name="TrackBorder" CornerRadius="28"
                Background="#2a2a2a"
                BorderBrush="#1a1a1a" BorderThickness="1"/>

        <!-- Shimmer sweep (shown while locked) -->
        <Border x:Name="ShimmerHost" CornerRadius="28" IsHitTestVisible="False">
            <Rectangle x:Name="ShimmerRect" Width="160" Height="56" HorizontalAlignment="Left">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#18FFFFFF" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.RenderTransform>
                    <TranslateTransform x:Name="SweepTransform" X="-180"/>
                </Rectangle.RenderTransform>
            </Rectangle>
        </Border>

        <!-- Hint text -->
        <TextBlock x:Name="HintText"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="13" IsHitTestVisible="False"
                   Text="▶ 밀어서 잠금 해제"
                   Foreground="#8a8a8a"/>

        <!-- Draggable thumb -->
        <Canvas x:Name="ThumbCanvas">
            <Border x:Name="ThumbBorder"
                    Width="48" Height="48"
                    CornerRadius="24"
                    Canvas.Left="4" Canvas.Top="4"
                    Background="#4ade80"
                    PointerPressed="Thumb_PointerPressed"
                    PointerMoved="Thumb_PointerMoved"
                    PointerReleased="Thumb_PointerReleased"
                    PointerCaptureLost="Thumb_PointerCaptureLost">
                <FontIcon x:Name="ThumbIcon"
                          Glyph="&#xE72E;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="18"
                          Foreground="#06210f"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
