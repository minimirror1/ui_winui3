<Window
    x:Class="AnimatronicsControlCenter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid x:Name="AppTitleBar" Height="32" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                <Button x:Name="BackButton" 
                        Style="{StaticResource NavigationBackButtonNormalStyle}"
                        Click="BackButton_Click"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"/>
                <TextBlock Text="Animatronics Control Center" 
                           VerticalAlignment="Center" 
                           Margin="12,0,0,0"
                           Style="{StaticResource CaptionTextBlockStyle}"/>
            </StackPanel>
        </Grid>

        <NavigationView x:Name="NavView" 
                        Grid.Row="1"
                        PaneDisplayMode="LeftCompact" 
                        SelectionChanged="NavView_SelectionChanged"
                        Loaded="NavView_Loaded">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="DashboardPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <Grid x:Name="SerialTrafficFooterHost"
                      Width="48"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,12">
                    <Button x:Name="SerialTrafficButton"
                            Click="SerialTrafficButton_Click"
                            Width="36"
                            Height="52"
                            Padding="0"
                            HorizontalAlignment="Center"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            ToolTipService.ToolTip="Serial activity">
                        <Border x:Name="SerialTrafficButtonChrome"
                                Width="28"
                                Height="44"
                                Padding="0"
                                CornerRadius="14"
                                Background="#10FFFFFF">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="8">
                                <Border x:Name="RxTrafficDot"
                                        Width="8"
                                        Height="8"
                                        CornerRadius="4"
                                        Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" />
                                <Border x:Name="TxTrafficDot"
                                        Width="8"
                                        Height="8"
                                        CornerRadius="4"
                                        Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" />
                            </StackPanel>
                        </Border>
                    </Button>
                </Grid>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>
